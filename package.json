{
  "name": "qa-automation-portfolio",
  "version": "1.0.0",
  "description": "QA automation portfolio: API & UI testing with Playwright, performance testing with k6 and JMeter",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test --project=api",
    "test:ui": "playwright test --project=ui-chromium",
    "test:headed": "playwright test --project=ui-chromium --headed",
    "report": "playwright show-report"
  },
  "keywords": [
    "qa",
    "test-automation",
    "playwright",
    "api-testing",
    "k6",
    "jmeter",
    "performance-testing"
  ],
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  }
}
